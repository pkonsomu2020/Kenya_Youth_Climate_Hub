# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────
/.next/
/out/
/build

# ── Environment variables (never commit secrets) ──────────
.env
.env.*
.env.local
.env.development
.env.production

# ── Local dev / scratch files (keep locally, not in git) ──
profiles.txt
scratch_create_bookings.sql

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing & coverage ────────────────────────────────────
/coverage

# ── Vercel ────────────────────────────────────────────────
.vercel

# ── OS & editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json

# ── Debug logs ────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──────────────────────────────────────────────────
*.local
